# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_API_BASE_URL="https://generativelanguage.googleapis.com/v1beta"

# Optional model overrides. Both default to gemini-3.5-flash.
GEMINI_TEXT_MODEL="gemini-3.5-flash"
GEMINI_VISION_MODEL="gemini-3.5-flash"
GEMINI_IMAGE_MODEL="gemini-3-pro-image"

# Required for real image generation from the local web app.
# Keep this server-side only; never expose it through a VITE_ prefixed variable.
OPENAI_API_KEY=""
OPENAI_IMAGE_MODEL="gpt-image-2"
# Optional: low, medium, high, or auto. Defaults by selected resolution.
OPENAI_IMAGE_QUALITY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
